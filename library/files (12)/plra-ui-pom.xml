<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- ============================================================ -->
    <!--  PLRA-UI POM — Builds Angular via Maven                     -->
    <!-- ============================================================ -->

    <parent>
        <groupId>com.td.plra</groupId>
        <artifactId>plra-parent</artifactId>
        <version>2.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>plra-ui</artifactId>
    <packaging>pom</packaging>  <!-- POM packaging — no JAR needed -->

    <n>PLRA UI (Angular 20)</n>
    <description>Angular frontend — compiled and packaged for Spring Boot</description>

    <properties>
        <!-- 
            IMPORTANT: Update this to match your angular.json outputPath.
            
            For Angular 17+, the outputPath in angular.json might be:
              "outputPath": "dist/plra-ui"
            
            Or for Angular 20 with the new build system:
              "outputPath": {
                "base": "dist/plra-ui",
                "browser": ""
              }
            
            The path below should point to where the final index.html 
            and JS/CSS bundles are generated.
        -->
        <angular.output.dir>${project.basedir}/dist/plra-ui/browser</angular.output.dir>
    </properties>

    <build>
        <plugins>

            <!-- ================================================== -->
            <!--  frontend-maven-plugin                              -->
            <!--  - Installs Node & NPM locally (no global install) -->
            <!--  - Runs npm install                                 -->
            <!--  - Runs ng build --configuration=production         -->
            <!-- ================================================== -->
            <plugin>
                <groupId>com.github.eirslett</groupId>
                <artifactId>frontend-maven-plugin</artifactId>
                <version>${frontend-maven-plugin.version}</version>

                <!-- Tell the plugin where the Angular project root is -->
                <configuration>
                    <workingDirectory>${project.basedir}</workingDirectory>
                    <nodeVersion>${node.version}</nodeVersion>
                    <npmVersion>${npm.version}</npmVersion>
                    <!-- Node is installed locally inside the project -->
                    <installDirectory>${project.basedir}/node</installDirectory>
                </configuration>

                <executions>

                    <!-- STEP 1: Install Node and NPM locally -->
                    <execution>
                        <id>install-node-and-npm</id>
                        <goals>
                            <goal>install-node-and-npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                    </execution>

                    <!-- STEP 2: Run npm install (or npm ci for CI/CD) -->
                    <execution>
                        <id>npm-install</id>
                        <goals>
                            <goal>npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                        <configuration>
                            <arguments>install</arguments>
                        </configuration>
                    </execution>

                    <!-- STEP 3: Run ng build --configuration=production -->
                    <execution>
                        <id>npm-build</id>
                        <goals>
                            <goal>npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                        <configuration>
                            <arguments>run build -- --configuration=production</arguments>
                        </configuration>
                    </execution>

                </executions>
            </plugin>

        </plugins>
    </build>

    <!-- ============================================================ -->
    <!--  PROFILE: Skip UI build during quick API-only development    -->
    <!--  Usage: mvn clean install -P skip-ui                         -->
    <!-- ============================================================ -->
    <profiles>
        <profile>
            <id>skip-ui</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>com.github.eirslett</groupId>
                        <artifactId>frontend-maven-plugin</artifactId>
                        <version>${frontend-maven-plugin.version}</version>
                        <executions>
                            <execution>
                                <id>install-node-and-npm</id>
                                <phase>none</phase>
                            </execution>
                            <execution>
                                <id>npm-install</id>
                                <phase>none</phase>
                            </execution>
                            <execution>
                                <id>npm-build</id>
                                <phase>none</phase>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>
