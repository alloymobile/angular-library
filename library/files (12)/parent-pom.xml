<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- ============================================================ -->
    <!--  PARENT POM — Multi-Module Build (Angular + Spring Boot)     -->
    <!-- ============================================================ -->

    <groupId>com.td.plra</groupId>
    <artifactId>plra-parent</artifactId>
    <version>2.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>PLRA Parent</name>
    <description>Parent POM for PLRA — Angular UI + Spring Boot API</description>

    <!-- ============================================================ -->
    <!--  MODULE ORDER MATTERS: UI builds first, then API copies it   -->
    <!-- ============================================================ -->
    <modules>
        <module>plra-ui</module>
        <module>plra-api</module>
    </modules>

    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Node/NPM versions — match your local environment -->
        <node.version>v22.12.0</node.version>
        <npm.version>10.9.0</npm.version>

        <!-- Frontend Maven Plugin version -->
        <frontend-maven-plugin.version>1.15.1</frontend-maven-plugin.version>
    </properties>

</project>
