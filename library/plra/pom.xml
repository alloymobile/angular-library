<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- ================================================================= -->
    <!-- PARENT POM — PLRA Multi-Module Build                              -->
    <!-- ================================================================= -->
    <!-- Build order: plra-ui (Angular) → plra-api (Spring Boot)           -->
    <!-- Result: single plra-api.jar with Angular static files embedded    -->
    <!--                                                                   -->
    <!-- Usage:                                                            -->
    <!--   mvn clean package              → full build (UI + API)          -->
    <!--   mvn clean package -pl plra-api → backend only (skip UI build)   -->
    <!--   mvn clean package -Pskip-ui    → backend only via profile       -->
    <!-- ================================================================= -->

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.1</version>
        <relativePath/>
    </parent>

    <groupId>com.td</groupId>
    <artifactId>plra-parent</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>PLRA - Product Lending Rate Administration</name>
    <description>
        Rate management system for ULOC (Unsecured Line of Credit)
        and ILOC (Investment Line of Credit) products.
    </description>

    <!-- ================================================================= -->
    <!-- MODULE ORDER: UI builds first, API second (copies UI dist)        -->
    <!-- ================================================================= -->
    <modules>
        <module>plra-ui</module>
        <module>plra-api</module>
    </modules>

    <!-- ================================================================= -->
    <!-- CENTRALIZED VERSION MANAGEMENT                                    -->
    <!-- ================================================================= -->
    <properties>
        <!-- Java -->
        <java.version>17</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Spring Boot is managed by parent BOM -->

        <!-- Libraries -->
        <mapstruct.version>1.5.5.Final</mapstruct.version>
        <lombok.version>1.18.30</lombok.version>
        <springdoc.version>2.8.6</springdoc.version>
        <querydsl.version>5.0.0</querydsl.version>
        <mssql.jdbc.version>12.4.2.jre11</mssql.jdbc.version>

        <!-- Frontend -->
        <node.version>v20.11.1</node.version>
        <npm.version>10.2.4</npm.version>
        <frontend-maven-plugin.version>1.15.1</frontend-maven-plugin.version>

        <!-- Testing -->
        <testcontainers.version>1.19.3</testcontainers.version>

        <!-- Code Quality -->
        <sonar.organization>td-plra</sonar.organization>
        <sonar.host.url>https://sonarcloud.io</sonar.host.url>
        <jacoco.version>0.8.11</jacoco.version>
    </properties>

    <!-- ================================================================= -->
    <!-- DEPENDENCY MANAGEMENT (inherited by child modules)                -->
    <!-- ================================================================= -->
    <dependencyManagement>
        <dependencies>
            <!-- MapStruct -->
            <dependency>
                <groupId>org.mapstruct</groupId>
                <artifactId>mapstruct</artifactId>
                <version>${mapstruct.version}</version>
            </dependency>
            <dependency>
                <groupId>org.mapstruct</groupId>
                <artifactId>mapstruct-processor</artifactId>
                <version>${mapstruct.version}</version>
            </dependency>

            <!-- QueryDSL -->
            <dependency>
                <groupId>com.querydsl</groupId>
                <artifactId>querydsl-jpa</artifactId>
                <version>${querydsl.version}</version>
                <classifier>jakarta</classifier>
            </dependency>
            <dependency>
                <groupId>com.querydsl</groupId>
                <artifactId>querydsl-apt</artifactId>
                <version>${querydsl.version}</version>
                <classifier>jakarta</classifier>
            </dependency>

            <!-- SQL Server JDBC -->
            <dependency>
                <groupId>com.microsoft.sqlserver</groupId>
                <artifactId>mssql-jdbc</artifactId>
                <version>${mssql.jdbc.version}</version>
            </dependency>

            <!-- OpenAPI -->
            <dependency>
                <groupId>org.springdoc</groupId>
                <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
                <version>${springdoc.version}</version>
            </dependency>

            <!-- Testcontainers -->
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>${testcontainers.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!-- ================================================================= -->
    <!-- PROFILES                                                          -->
    <!-- ================================================================= -->
    <profiles>
        <!-- Skip UI build for backend-only development -->
        <profile>
            <id>skip-ui</id>
            <modules>
                <module>plra-api</module>
            </modules>
        </profile>

        <!-- Production build — full optimisation -->
        <profile>
            <id>prod</id>
            <properties>
                <angular.configuration>production</angular.configuration>
            </properties>
        </profile>
    </profiles>
</project>
